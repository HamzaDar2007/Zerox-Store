ENUM
NOT NULL, DEFAULT 'customer'
customer | seller | admin
is_email_verified
BOOLEAN
DEFAULT false
Email verify hua ya nahi
is_active
BOOLEAN
DEFAULT true
Account active hai ya nahi
profile_image
VARCHAR(500)
NULLABLE
S3 image URL
deleted_at
TIMESTAMP
NULLABLE
