# ===========================================
# LabVerse E-Commerce Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# Variables marked [REQUIRED] have no fallback and will cause errors if missing.
#
# ⚠️  WARNING: Do NOT use example values in production!
# Generate strong random secrets for JWT_SECRET, DB_PASSWORD,
# SUPER_ADMIN_PASSWORD, and all API keys before deploying.

# -------------------------------------------
# Application
# -------------------------------------------
NODE_ENV=development
PORT=3001

# Comma-separated list of allowed frontend origins for CORS
FRONTEND_URLS=http://localhost:3000,http://localhost:4200

# Express rate limit: max requests per 60-second window (default: 300)
RATE_LIMIT=300

# -------------------------------------------
# Database (PostgreSQL)
# -------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=ecommerce

# Enable TypeORM SQL logging (true/false)
TYPEORM_LOGGING=false

# -------------------------------------------
# Authentication (JWT)
# -------------------------------------------
# [REQUIRED] Use a strong random secret (min 32 chars) in production
# ⚠️  CHANGE THIS! Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-strong-random-secret-at-least-32-chars

# Token expiry for SharedModule JWT (default: 7d)
# Note: Access tokens in AuthModule are hardcoded to 15m
JWT_EXPIRES_IN=7d

# -------------------------------------------
# Rate Limiting (NestJS Throttler - separate from express-rate-limit)
# -------------------------------------------
# Time-to-live window in milliseconds (default: 60000 = 60s)
THROTTLE_TTL=60000
# Max requests per TTL window (default: 100)
THROTTLE_LIMIT=100

# -------------------------------------------
# File Storage (Cloudflare R2 / S3-compatible)
# -------------------------------------------
# [REQUIRED if using file uploads]
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# -------------------------------------------
# Email / SMTP (nodemailer via MailModule)
# -------------------------------------------
# Set to 'false' to disable email sending entirely
NOTIFICATION_ENABLED=true
MAIL_FROM=Labverse <noreply@labverse.com>
ADMIN_EMAIL=admin@labverse.com

# URL used in email templates for links back to the frontend
FRONTEND_URL=http://localhost:3000

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# [REQUIRED if NOTIFICATION_ENABLED=true]
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# -------------------------------------------
# Super Admin Seed (used by seed scripts only)
# -------------------------------------------
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=superadmin@labverse.org
# ⚠️  CHANGE THIS in production! Use a strong unique password.
SUPER_ADMIN_PASSWORD=SuperAdmin@123!
SUPER_ADMIN_PHONE=+923000000000

# -------------------------------------------
# Stripe Payments
# -------------------------------------------
# [REQUIRED if using payments]
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
