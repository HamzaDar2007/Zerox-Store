# ============================================
# LabVerse E-Commerce Monorepo
# Parent-level .gitignore
# ============================================

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# IDE files (workspace-level)
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Environment variables (global)
.env
.env.local
.env.*.local

# Logs (any level)
*.log
logs/
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependencies (covered by subprojects, but safe to include)
node_modules/

# Build outputs (covered by subprojects)
dist/
build/
*/dist/
*/build/

# Testing artifacts
coverage/
.nyc_output/
test-results*.json

# Temporary files
*.tmp
*.temp
.tmp/
.temp/

# Lock files for other package managers (standardized on npm)
# Uncomment if you want to exclude these:
# yarn.lock
# pnpm-lock.yaml
